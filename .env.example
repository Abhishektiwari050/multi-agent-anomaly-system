RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

EXCHANGE_NAME=agent.events
DLX_NAME=agent.dlx

HEARTBEAT_INTERVAL_SECONDS=30
HEARTBEAT_TIMEOUT_SECONDS=90

HIGH_SEVERITY_THRESHOLD=-0.15
MEDIUM_SEVERITY_THRESHOLD=-0.08

STATE_FILE_PATH=/app/state/tasks.json
LOG_DIR=/app/logs
