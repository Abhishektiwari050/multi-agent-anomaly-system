# RabbitMQ URL format (AMQP/AMQPS) - Priority format
RABBITMQ_URL=amqps://user:password@host/vhost

# Individual Connection Details (Fallback if URL is not provided)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Supervisor/Heartbeat configurations
HEARTBEAT_INTERVAL_SECONDS=30
HIGH_SEVERITY_THRESHOLD=-0.15
MEDIUM_SEVERITY_THRESHOLD=-0.08
